#! /usr/local/bin/vvp
:ivl_version "10.3 (stable)" "(v10_3)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "system";
:vpi_module "vhdl_sys";
:vpi_module "v2005_math";
:vpi_module "va_math";
S_0x96d6f48 .scope module, "tb_one_hot" "tb_one_hot" 2 1;
 .timescale 0 0;
v0x96d4a08_0 .var "in", 3 0;
v0x96d4a90_0 .net "valid", 0 0, v0x96d4970_0;  1 drivers
S_0x96d7010 .scope module, "uut" "one_hot" 2 6, 3 1 0, S_0x96d6f48;
 .timescale 0 0;
    .port_info 0 /INPUT 4 "in"
    .port_info 1 /OUTPUT 1 "valid"
v0x96b4a70_0 .net "in", 3 0, v0x96d4a08_0;  1 drivers
v0x96d4970_0 .var "valid", 0 0;
E_0x96b4a48 .event edge, v0x96b4a70_0;
    .scope S_0x96d7010;
T_0 ;
    %wait E_0x96b4a48;
    %load/vec4 v0x96b4a70_0;
    %pad/u 32;
    %pushi/vec4 0, 0, 32;
    %cmp/e;
    %flag_get/vec4 4;
    %inv;
    %load/vec4 v0x96b4a70_0;
    %pad/u 32;
    %load/vec4 v0x96b4a70_0;
    %pad/u 32;
    %subi 1, 0, 32;
    %and;
    %pushi/vec4 0, 0, 32;
    %cmp/e;
    %flag_get/vec4 4;
    %and;
    %store/vec4 v0x96d4970_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x96d6f48;
T_1 ;
    %vpi_call 2 12 "$dumpfile", "tb_one_hot.vcd" {0 0 0};
    %vpi_call 2 13 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x96d6f48 {0 0 0};
    %vpi_call 2 15 "$monitor", "in=%b  valid=%b", v0x96d4a08_0, v0x96d4a90_0 {0 0 0};
    %pushi/vec4 0, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 1, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 2, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 3, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 4, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 5, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 6, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 7, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 8, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 9, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 10, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 11, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 12, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 13, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 14, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %pushi/vec4 15, 0, 4;
    %store/vec4 v0x96d4a08_0, 0, 4;
    %delay 10, 0;
    %vpi_call 2 33 "$finish" {0 0 0};
    %end;
    .thread T_1;
